{
  "schemaVersion": 1,
  "id": "meteor-plusplus",
  "version": "${version}",
  "name": "Meteor++",
  "description": "Meteor Client addon with extra features",
  "authors": [
    "zychen027"
  ],
  "contact": {
    "homepage": "https://github.com/zychen027/MeteorPlusPlus",
    "sources": "https://github.com/zychen027/MeteorPlusPlus"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      {
        "adapter": "kotlin",
        "value": "com.zychen027.MeteorPlusPlus.MeteorPlusPlusAddon"
      }
    ]
  },
  "mixins": [],
  "custom": {
    "meteor-client:addon": true
  },
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-language-kotlin": ">=1.13.0",
    "minecraft": "~1.21.8",
    "meteor-client": "*"
  }
}
